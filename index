<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Emoji Picker</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cell-size: 4.3rem;
    --emoji-size: 3rem;
  }

  body {
    background: #ffffff;
    color: #1a1a1a;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }
  body.dark {
    background: #1a1a1a;
    color: #f0f0f0;
  }

  header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #ffffff;
    border-bottom: 1px solid #e0e0e0;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  body.dark header {
    background: #1a1a1a;
    border-bottom-color: #333333;
  }

  h1 {
    font-size: 15px;
    font-weight: 600;
    color: #666666;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }
  body.dark h1 { color: #999999; }

  /* Size presets */
  #size-presets {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    justify-content: center;
  }

  .size-btn {
    background: none;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    cursor: pointer;
    color: #888888;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    font-family: inherit;
    transition: background 0.12s, color 0.12s;
    white-space: nowrap;
  }
  body.dark .size-btn {
    border-color: #333333;
    color: #666666;
  }
  .size-btn:hover {
    background: #f5f5f5;
    color: #444444;
    border-color: #cccccc;
  }
  body.dark .size-btn:hover {
    background: #242424;
    color: #aaaaaa;
    border-color: #444444;
  }
  .size-btn.active {
    background: rgb(39, 131, 222);
    border-color: rgb(39, 131, 222);
    color: #ffffff;
  }
  body.dark .size-btn.active {
    background: rgb(39, 131, 222);
    border-color: rgb(39, 131, 222);
    color: #ffffff;
  }

  #theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    flex-shrink: 0;
  }
  body.dark #theme-toggle { color: #f0f0f0; }
  #theme-toggle:hover { background: #f5f5f5; }
  body.dark #theme-toggle:hover { background: #242424; }

  main {
    padding: 90px 19px 90px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .category {
    margin-bottom: 32px;
  }

  .category-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #666666;
    margin-bottom: 8px;
  }
  body.dark .category-title { color: #999999; }

  .emoji-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
  }

  .emoji-cell {
    width: var(--cell-size);
    height: var(--cell-size);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--emoji-size);
    cursor: pointer;
    border-radius: 8px;
    user-select: none;
    line-height: 1;
  }
  .emoji-cell:hover { background: rgb(39, 131, 222); }

  /* Invisible trigger zone — covers entire dash column */
  #nav-trigger {
    position: fixed;
    right: 20px;
    width: 40px;
    z-index: 99;
  }

  /* Nav panel — sits on top of trigger, pointer-events only when open */
  #nav-panel {
    position: fixed;
    right: 20px;
    z-index: 100;
    display: flex;
    flex-direction: column;
    gap: 0;
    pointer-events: none;
  }
  #nav-panel.open {
    pointer-events: auto;
  }

  /* Background card */
  #nav-card {
    position: absolute;
    inset: -6px 0;
    background: #ffffff;
    border: 1px solid #e0e0e0;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
    z-index: -1;
  }
  body.dark #nav-card {
    background: #242424;
    border-color: #333333;
    box-shadow: -4px 0 16px rgba(0,0,0,0.4);
  }
  #nav-panel.open #nav-card { opacity: 1; }

  .nav-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
    padding: 6px 16px 6px 14px;
    cursor: pointer;
    border-radius: 6px 0 0 6px;
  }

  #nav-panel { width: 160px; }

  .nav-label {
    font-size: 13px;
    font-weight: 500;
    white-space: nowrap;
    color: #888888;
    opacity: 0;
    width: 0;
    overflow: hidden;
    flex: 1;
    text-align: left;
    transition: opacity 0.22s ease, width 0.22s ease, color 0.15s ease;
    pointer-events: none;
  }
  #nav-panel.open .nav-label {
    opacity: 1;
    width: auto;
    pointer-events: auto;
  }

  .nav-line {
    width: 10px;
    height: 2px;
    border-radius: 1px;
    background: #888888;
    flex-shrink: 0;
    transition: background 0.15s ease;
  }

  /* Active state */
  .nav-row.active .nav-label { color: rgb(39, 131, 222); }
  .nav-row.active .nav-line  { background: rgb(39, 131, 222); }

  /* Hovered — darker in light, lighter in dark */
  .nav-row.hovered:not(.active) .nav-label { color: #333333; }
  .nav-row.hovered:not(.active) .nav-line  { background: #333333; }
  body.dark .nav-row.hovered:not(.active) .nav-label { color: #ffffff; }
  body.dark .nav-row.hovered:not(.active) .nav-line  { background: #ffffff; }

  /* Loader overlay */
  #loader {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    /*transition: opacity 0.1s ease;*/
  }
  #loader.visible {
    opacity: 1;
    pointer-events: auto;
  }
  /* ===== ЛОАДЕР — настройки ===== */
  .loader-spinner {
    width: 28px;                              /* размер спиннера */
    height: 28px;
    border: 3px solid rgba(0,0,0,0.08);               /* толщина и цвет трека */
    border-top-color: rgb(39, 131, 222);     /* цвет активной дуги */
    border-radius: 50%;
    animation: spin 0.6s linear infinite;    /* скорость: меньше = быстрее */
  }
  body.dark .loader-spinner {
    border-color: rgba(255,255,255,0.12);                   /* трек в тёмной теме */
    border-top-color: rgb(39, 131, 222);     /* активная дуга в тёмной теме */
  }
  /* ============================== */
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Toast */
  #toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(12px);
    background: #1a1a1a;
    color: #ffffff;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s, transform 0.15s;
    white-space: nowrap;
  }
  body.dark #toast { background: #f0f0f0; color: #1a1a1a; }
  #toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
</style>
</head>
<body>

<header>
  <h1>Эмодзи</h1>
  <div id="size-presets">
    <button class="size-btn" data-cell="2.4rem" data-emoji="1.6rem">S</button>
    <button class="size-btn" data-cell="3rem" data-emoji="2.1rem">M</button>
    <button class="size-btn active" data-cell="4.3rem" data-emoji="3rem">L</button>
  </div>
  <button id="theme-toggle" title="Переключить тему" aria-label="Переключить тему"></button>
</header>

<main id="main"></main>

<div id="loader"><div class="loader-spinner"></div></div>
<div id="toast"></div>

<div id="nav-trigger"></div>
<div id="nav-panel">
  <div id="nav-card"></div>
</div>

