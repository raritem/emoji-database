// Theme
let dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
function applyTheme() {
  document.body.classList.toggle('dark', dark);
  document.getElementById('theme-toggle').innerHTML = dark ? SVG_SUN : SVG_MOON;
}
applyTheme();

document.getElementById('theme-toggle').addEventListener('click', () => {
  dark = !dark;

  // Show loader synchronously so it paints before the theme change
  loader.classList.add('visible');

  // Yield to browser to paint loader, then apply theme change
  setTimeout(() => {
    applyTheme();
    requestAnimationFrame(() => {
      loader.classList.remove('visible');
    });
  }, 0);
});

// Size presets
const root = document.documentElement;
const loader = document.getElementById('loader');

document.querySelectorAll('.size-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    if (btn.classList.contains('active')) return;

    document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    // Show loader synchronously so it paints before the heavy reflow
    loader.classList.add('visible');

    // Yield to browser to paint loader, then apply size change
    setTimeout(() => {
      root.style.setProperty('--cell-size', btn.dataset.cell);
      root.style.setProperty('--emoji-size', btn.dataset.emoji);
      requestAnimationFrame(() => {
        loader.classList.remove('visible');
      });
    }, 0);
  });
});

// Build grid + nav
const main = document.getElementById('main');
const navPanel = document.getElementById('nav-panel');
const navTrigger = document.getElementById('nav-trigger');

function positionNavPanel() {
  const h = navPanel.offsetHeight;
  const top = Math.round((window.innerHeight - h) / 2);
  navPanel.style.top = top + 'px';
  // Trigger covers exactly the dash column area
  navTrigger.style.top = top + 'px';
  navTrigger.style.height = h + 'px';
}
window.addEventListener('resize', positionNavPanel);
const navRows = [];
let manualActiveIdx = null;

EMOJIS.forEach((cat, i) => {
  const row = document.createElement('div');
  row.className = 'nav-row' + (i === 0 ? ' active' : '');

  const label = document.createElement('div');
  label.className = 'nav-label';
  label.textContent = cat.name;

  const line = document.createElement('div');
  line.className = 'nav-line';

  row.appendChild(label);
  row.appendChild(line);
  navPanel.appendChild(row);
  navRows.push(row);

  row.addEventListener('mouseenter', () => {
    navRows.forEach((r, j) => r.classList.toggle('hovered', j === i));
  });

  row.addEventListener('mouseleave', () => {
    row.classList.remove('hovered');
  });

  row.addEventListener('click', () => {
    manualActiveIdx = i;
    setActive(i);
    const target = document.getElementById('cat-' + cat.name);
    if (target) {
      const headerH = document.querySelector('header').offsetHeight;
      const top = target.getBoundingClientRect().top + window.scrollY - headerH - 12;
      window.scrollTo({ top, behavior: 'smooth' });
    }
  });
});

navPanel.addEventListener('mouseleave', (e) => {
  // Don't close if moving to trigger
  if (e.relatedTarget === navTrigger) return;
  navRows.forEach(r => r.classList.remove('hovered'));
  navPanel.classList.remove('open');
});

// Trigger opens the panel
navTrigger.addEventListener('mouseenter', () => {
  navPanel.classList.add('open');
});
navTrigger.addEventListener('mouseleave', (e) => {
  // Don't close if moving into the panel itself
  if (navPanel.contains(e.relatedTarget)) return;
  navRows.forEach(r => r.classList.remove('hovered'));
  navPanel.classList.remove('open');
});

positionNavPanel();

function setActive(idx) {
  navRows.forEach((r, i) => r.classList.toggle('active', i === idx));
}

let categoryEls = [];

window.addEventListener('scroll', () => {
  if (manualActiveIdx !== null) {
    const scrollIdx = getScrollActive();
    if (scrollIdx === manualActiveIdx) manualActiveIdx = null;
    else return;
  }
  setActive(getScrollActive());
}, { passive: true });

function getScrollActive() {
  const mid = window.scrollY + window.innerHeight / 2;
  let activeIdx = 0;
  categoryEls.forEach((el, i) => {
    if (el.offsetTop <= mid) activeIdx = i;
  });
  return activeIdx;
}

EMOJIS.forEach(cat => {
  const section = document.createElement('div');
  section.className = 'category';
  section.id = 'cat-' + cat.name;

  const title = document.createElement('div');
  title.className = 'category-title';
  title.textContent = cat.name;
  section.appendChild(title);

  const grid = document.createElement('div');
  grid.className = 'emoji-grid';

  cat.emojis.forEach(emoji => {
    const cell = document.createElement('div');
    cell.className = 'emoji-cell';
    cell.textContent = emoji;
    cell.title = emoji;
    cell.addEventListener('click', () => copyEmoji(emoji));
    grid.appendChild(cell);
  });

  section.appendChild(grid);
  main.appendChild(section);
  categoryEls.push(section);
});

// Toast
let toastTimer;
const toast = document.getElementById('toast');
function showToast(msg) {
  toast.textContent = msg;
  toast.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => toast.classList.remove('show'), 1500);
}

function copyEmoji(emoji) {
  navigator.clipboard.writeText(emoji).then(() => {
    showToast(emoji + ' скопировано');
  }).catch(() => {
    const ta = document.createElement('textarea');
    ta.value = emoji;
    ta.style.position = 'fixed';
    ta.style.opacity = '0';
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    showToast(emoji + ' скопировано');
  });
}
</script>
